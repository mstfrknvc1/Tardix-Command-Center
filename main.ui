   <string notr="true">/* Ana Pencere Arka Planı */
QMainWindow {
    background-color: #121212;
}

/* Tüm Yazılar */
QLabel {
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
}

/* Neon Butonlar */
QPushButton {
    background-color: #1a1a1a;
    color: #00ff9d;  /* Alienware Yeşili */
    border: 2px solid #00ff9d;
    border-radius: 8px;
    padding: 8px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #00ff9d;
    color: #000000;
}
QPushButton:pressed {
    background-color: #00cc7a;
}

/* İlerleme Çubukları (CPU/RAM Grafikleri için) */
QProgressBar {
    border: 1px solid #444;
    border-radius: 5px;
    text-align: center;
    color: white;
    background-color: #222;
}
QProgressBar::chunk {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #00ff9d, stop:1 #00bcd4);
    border-radius: 4px;
}</string>
