  <property name="styleSheet">
   <string notr="true">/* Ana Pencere Arka Planı */
QMainWindow {
    background-color: #121212;
}

/* Tüm Yazılar */
QLabel {
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
}

/* Neon Butonlar */
QPushButton {
    background-color: #1a1a1a;
    color: #003B6F;  /* Alienware Yeşili */
    border: 2px solid #1C3F95;
    border-radius: 8px;
    padding: 8px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #1C3F95;
    color: #000000;
}
QPushButton:pressed {
    background-color: #1C3F95;
}

/* ComboBox */
QComboBox {
    background-color: #1a1a1a;
    color: #e0e0e0;
    border: 2px solid #1C3F95;
    border-radius: 8px;
    padding: 6px 10px;
}
QComboBox QAbstractItemView {
    background-color: #1a1a1a;
    color: #e0e0e0;
    selection-background-color: #1C3F95;
}

/* Slider */
QSlider::groove:horizontal {
    height: 8px;
    background: #222;
    border-radius: 4px;
}
QSlider::handle:horizontal {
    width: 18px;
    margin: -6px 0;
    border-radius: 9px;
    background: #1C3F95;
}

/* GroupBox */
QGroupBox {
    border: 2px solid #2a2a33;
    border-radius: 10px;
    margin-top: 10px;
    padding: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #e0e0e0;
}

/* Color swatches */
QFrame#selectedStaticSwatch, QFrame#selectedMorphSwatch {
    border: 2px solid #1C3F95;
    border-radius: 8px;
}

/* Checkbox */
QCheckBox {
    spacing: 10px;
    color: #e0e0e0;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
}
QCheckBox::indicator:unchecked {
    border: 2px solid #1C3F95;
    background: #1a1a1a;
    border-radius: 4px;
}
QCheckBox::indicator:checked {
    border: 2px solid #1C3F95;
    background: #1C3F95;
    border-radius: 4px;
}

/* İlerleme Çubukları (CPU/RAM Grafikleri için) */
QProgressBar {
    border: 1px solid #444;
    border-radius: 5px;
    text-align: center;
    color: white;
    background-color: #222;
}
QProgressBar::chunk {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #00ff9d, stop:1 #00bcd4);
    border-radius: 4px;
}</string>
