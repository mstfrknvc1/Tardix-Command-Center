  <property name="styleSheet">
   <string notr="true">QMainWindow { background-color: #121212; }
QWidget { background-color: #121212; }
QLabel { color: #e0e0e0; font-family: "Segoe UI"; font-size: 14px; }
QPushButton { background-color: #1a1a1a; color: #4a90d9; border: 2px solid #1C3F95; border-radius: 8px; padding: 8px; font-weight: bold; }
QPushButton:hover { background-color: #1C3F95; color: #ffffff; }
QPushButton:pressed { background-color: #0d2461; }
QComboBox { background-color: #1a1a1a; color: #e0e0e0; border: 2px solid #1C3F95; border-radius: 8px; padding: 6px 10px; }
QComboBox::drop-down { border: none; }
QComboBox QAbstractItemView { background-color: #1e1e2e; color: #e0e0e0; selection-background-color: #1C3F95; border: 1px solid #1C3F95; }
QSlider::groove:horizontal { height: 8px; background: #2a2a3a; border-radius: 4px; }
QSlider::handle:horizontal { width: 18px; height: 18px; margin: -5px 0; border-radius: 9px; background: #1C3F95; }
QSlider::sub-page:horizontal { background: #1C3F95; border-radius: 4px; }
QGroupBox { border: 2px solid #2a2a3a; border-radius: 10px; margin-top: 14px; padding: 10px 8px 8px 8px; color: #e0e0e0; }
QGroupBox::title { subcontrol-origin: margin; left: 12px; padding: 0 6px; color: #8ab4f8; font-weight: bold; }
QCheckBox { spacing: 10px; color: #e0e0e0; }
QCheckBox::indicator { width: 18px; height: 18px; border: 2px solid #1C3F95; background: #1a1a1a; border-radius: 4px; }
QCheckBox::indicator:checked { background: #1C3F95; }
QLineEdit { background-color: #1a1a1a; color: #e0e0e0; border: 2px solid #2a2a3a; border-radius: 6px; padding: 6px; }
QLineEdit:focus { border: 2px solid #00ff9d; }
QScrollArea { border: none; background: transparent; }
QScrollBar:vertical { background: #1a1a1a; width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: #1C3F95; border-radius: 4px; }</string>
